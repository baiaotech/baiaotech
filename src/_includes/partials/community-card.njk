{% set data = community.data %}
{% set cover = data.cover_image | localAsset %}
<article
  class="listing-row listing-row--community {{ 'listing-row--with-media' if cover else 'listing-row--no-media' }}"
  data-card
  data-reveal
  data-searchable="{{ data.title }} {{ data.state }} {{ data.city }} {{ data.tags | join(' ') }}"
  data-state="{{ data.state }}"
>
  <div class="listing-row__territory">
    <span>{{ data.state }}</span>
  </div>

  <div class="listing-row__body">
    <p class="listing-row__eyebrow">
      {{ data.state | stateName }}{% if data.city %} · {{ data.city }}{% endif %}
    </p>
    <h3 class="listing-row__title"><a href="{{ community.url | url }}">{{ data.title }}</a></h3>
    <p class="listing-row__summary listing-row__summary--clamped">
      {{ community.templateContent | striptags }}
    </p>
    {% if data.tags.length %}
      <ul class="listing-row__meta-list" aria-label="Tags">
        {% for tag in data.tags.slice(0, 4) %}
          <li>{{ tag }}</li>
        {% endfor %}
      </ul>
    {% endif %}
  </div>

  {% if cover %}
    <div class="listing-row__media listing-row__media--community" style="--listing-image: url('{{ cover | url }}');"></div>
  {% endif %}

  <div class="listing-row__cta listing-row__cta--links">
    {% if data.website %}<a class="text-link" href="{{ data.website }}">Site</a>{% endif %}
    {% if data.instagram %}<a class="text-link" href="{{ data.instagram }}">Instagram</a>{% endif %}
    <a class="text-link" href="{{ community.url | url }}">Detalhes</a>
  </div>
</article>
